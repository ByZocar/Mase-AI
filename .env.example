# =============================================================================
# Mase Engine — Environment template
# Copy to .env.local and fill in your values.
# =============================================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_POOLER_HOST=aws-1-us-west-2.pooler.supabase.com
SUPABASE_POOLER_USER=postgres.YOUR-PROJECT-REF

# ---- LLMs (at least one) ----
# Gemini (Google AI Studio): https://aistudio.google.com/
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash-exp

# OpenAI (or OpenRouter compatible)
# OPENAI_API_KEY=sk-...

# Local Ollama fallback (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# ---- ElevenLabs (voice notes) ----
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_DEFAULT_VOICE_ID=BXEoDUvSz0PGA1yx0mkm
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ---- Scraping ----
APIFY_API_KEY=apify_api_...
VALUESERP_API_KEY=...

# ---- Email ----
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# ---- WhatsApp (WAHA self-hosted via Docker) ----
WAHA_BASE_URL=http://localhost:3030
WAHA_API_KEY=mase-local-secret
WAHA_SESSION=default

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3001
APP_NAME=Mase Engine
NODE_ENV=development
